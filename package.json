{
  "name": "p2p-zip-transfer",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/client",
    "packages/server"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev -w packages/client",
    "dev:server": "npm run dev -w packages/server",
    "build": "npm run build:client && npm run build:server",
    "build:client": "npm run build -w packages/client",
    "build:server": "npm run build -w packages/server",
    "start": "npm run start -w packages/server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
